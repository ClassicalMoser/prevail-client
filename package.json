    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-boundaries": "^0.5.3",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-solid": "^2.11.11"
